    "@types/jest": "^29.0.0",
    "@types/reflect-metadata": "^0.1.0",
    "amqplib": "^0.10.9",
    "aws-sdk": "^2.1692.0",
    "bcrypt-nodejs": "0.0.3",
    "concurrently": "^9.2.1",
    "dotenv": "^10.0.0",
    "fastify": "^5.6.1",
    "glob": "^11.0.3",
    "http-status": "^1.5.2",
    "jest": "^29.0.0",
    "keycloak-connect": "^26.1.1",
