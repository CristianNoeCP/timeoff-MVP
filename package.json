  "author": "CristianNoeCP",
  "scripts": {
    "start": "yarn build && node ./dist/src/app.js",
    "build": "yarn build:clean && yarn build:tsc && yarn build:di",
    "configure-rabbitmq": "ts-node ./src/scripts/configure-rabbitmq.ts",
    "consume-rabbitmq": "ts-node ./src/scripts/consume-rabbitmq.ts",
    "build:tsc": "tsc -p tsconfig.json",
    "build:clean": "rm -R ./dist; exit 0",
    "build:di": "cp .env dist/src",
    "test": "yarn test:unit",
    "test:unit": "NODE_ENV=test jest"
  },
